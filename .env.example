# ============================================================
# HealthConnect — AI Symptom Checker & Telemedicine Platform
# Copy this file to .env and fill in your real values
# NEVER commit the actual .env file to version control
# ============================================================

# ──────────────────────────────────────────────
# SERVER
# ──────────────────────────────────────────────
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5000

# ──────────────────────────────────────────────
# DATABASE — MySQL
# ──────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=healthconnect_db
DB_CONNECTION_LIMIT=10

# ──────────────────────────────────────────────
# AUTHENTICATION — JWT
# ──────────────────────────────────────────────
# IMPORTANT: Use a long, random string (64+ chars) for production
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_64_chars
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=your_refresh_token_secret_also_change_this_in_production
JWT_REFRESH_EXPIRES_IN=7d

# ──────────────────────────────────────────────
# GOOGLE OAUTH2
# ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# ──────────────────────────────────────────────
# AI Provider — 'huggingface' (free) or 'openai' (paid)
# ──────────────────────────────────────────────
AI_PROVIDER=huggingface

# Hugging Face (free tier for development)
HF_TOKEN=hf_your_huggingface_token_here
HF_MODEL=meta-llama/Llama-3.1-8B-Instruct

# OpenAI (for production — set AI_PROVIDER=openai)
OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.3

# ──────────────────────────────────────────────
# REDIS (for caching & rate limiting)
# ──────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL=3600

# ──────────────────────────────────────────────
# EMAIL — NodeMailer / SendGrid
# ──────────────────────────────────────────────
EMAIL_SERVICE=sendgrid
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USER=apikey
EMAIL_PASSWORD=your_sendgrid_api_key
EMAIL_FROM=noreply@healthconnect.health
EMAIL_FROM_NAME=HealthConnect

# ──────────────────────────────────────────────
# SMS — Africa's Talking
# ──────────────────────────────────────────────
AT_API_KEY=your_africas_talking_api_key
AT_USERNAME=your_africas_talking_username
AT_SENDER_ID=HealthConnect

# ──────────────────────────────────────────────
# SMS — Twilio (alternative)
# ──────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ──────────────────────────────────────────────
# PAYMENTS — Stripe
# ──────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# ──────────────────────────────────────────────
# PAYMENTS — MTN Mobile Money
# ──────────────────────────────────────────────
MTN_MOMO_API_KEY=your_mtn_momo_api_key
MTN_MOMO_USER_ID=your_mtn_momo_user_id
MTN_MOMO_SUBSCRIPTION_KEY=your_mtn_subscription_key
MTN_MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com

# ──────────────────────────────────────────────
# FILE STORAGE — AWS S3 Compatible
# ──────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=healthconnect-uploads

# ──────────────────────────────────────────────
# ENCRYPTION
# ──────────────────────────────────────────────
ENCRYPTION_KEY=your_32_char_aes256_encryption_key_here
ENCRYPTION_IV=your_16_char_iv_here

# ──────────────────────────────────────────────
# RATE LIMITING
# ──────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5

# ──────────────────────────────────────────────
# VECTOR DATABASE — Pinecone (for RAG)
# ──────────────────────────────────────────────
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX_NAME=healthconnect-medical-knowledge

# ──────────────────────────────────────────────
# SESSION
# ──────────────────────────────────────────────
SESSION_SECRET=your_session_secret_here
OTP_EXPIRES_IN=300000
